# ═══════════════════════════════════════════════════
# ACRE Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════

# ── LLM APIs ────────────────────────────────────────
OPENAI_API_KEY=sk-...
HF_TOKEN=hf_...                         # HuggingFace token for CodeLlama

# ── GitHub ──────────────────────────────────────────
GITHUB_TOKEN=ghp_...                    # Personal access token (repo read)
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ── Postgres ────────────────────────────────────────
POSTGRES_URL=postgresql://acre:password@localhost:5432/acre
POSTGRES_PASSWORD=strong_password_here

# ── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ────────────────────────────────────────────
JWT_SECRET=very_long_random_secret_here

# ── AWS ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
S3_BUCKET=acre-artifacts-123456789012

# ── Services (local dev) ────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
MLFLOW_TRACKING_URI=http://localhost:5000
INGESTION_SERVICE_URL=http://localhost:8080
AGENT_SERVICE_URL=http://localhost:8082

# ── Fine-tuning ─────────────────────────────────────
BASE_MODEL=codellama/CodeLlama-7b-Instruct-hf
OUTPUT_DIR=./finetuned_model
FINETUNED_MODEL_PATH=                    # leave blank to use GPT-4o only
OLLAMA_URL=http://localhost:11434        # if serving via Ollama
FINETUNED_MODEL_NAME=codellama-acre

# ── Celery ──────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Dashboard ───────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ── Monitoring ──────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Sandbox ─────────────────────────────────────────
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_S=30
